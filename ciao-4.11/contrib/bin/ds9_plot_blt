import sys
import os


infile="/soft/ciao/test/smoke/data/tools-dme2.fits[cols time,count_rate]"


from pycrates import read_file
tab = read_file(infile)

def get_col(k):
    kcol = tab.get_column(k)
    k_vals = kcol.values.copy()
    k_name = kcol.name
    k_units = kcol.unit
    k_label = "{} [{}]".format(k_name, k_units)
    return k_vals, k_label

x_vals,x_label = get_col(0)
y_vals,y_label = get_col(1)


import subprocess

#with subprocess.Popen( [ "xpaset", "ds9", "plot", "new"], stdin=subprocess.PIPE ) as xpa:
    
xpa = subprocess.Popen( [ "xpaset", "ds9", "plot", "new"], stdin=subprocess.PIPE ) 
for x,y in zip(x_vals, y_vals):
    pair = "{} {}\n".format(x,y)
    pb = pair.encode()
    xpa.stdin.write(pb)
        
xpa.communicate()
#xpa.close()
    

def xpa_cmd( access_point, command ):
    cc = ["xpaset", "-p", access_point ]
    cc.extend( command.split(' '))    
    print(cc)
    xpa = subprocess.Popen(cc)
    xpa.communicate()

xpa_cmd("ds9", "plot view line no")
xpa_cmd("ds9", "plot view step yes")
xpa_cmd("ds9", "plot line step width 2")
xpa_cmd("ds9", "plot graph labels title {Wild Thing}")
xpa_cmd("ds9", "plot graph labels xaxis {R.A. [deg]}")
xpa_cmd("ds9", "plot graph labels yaxis {Dec. [deg]}")
        








